{
  "$schema": "https://screens.gitci.com/schemas/scene-set-template.gitci.schema.json",
  "schemaVersion": 1,
  "id": "gitci.core.basic-launch",
  "name": "Basic Launch Screens",
  "pack": "gitci.core",
  "summary": "A starter App Store screenshot set with a hero, a close-up feature, and an overview scene.",
  "tags": ["app-store", "starter", "device"],
  "sceneSet": {
    "schemaVersion": 1,
    "id": "launch",
    "name": "Launch Screens",
    "targets": [
      "appstore.iphone.6_9.portrait",
      "appstore.ipad.13.portrait",
      "appstore.mac.16_10"
    ],
    "appearanceByTarget": {
      "appstore.*": "light"
    },
    "theme": {
      "id": "gitci.theme.clean-editorial",
      "palette": "gitci.palette.gitci-blue",
      "paletteMap": {
        "--gitci-color-bg": 0,
        "--gitci-color-primary": 0.5,
        "--gitci-color-secondary": 0.75,
        "--gitci-color-fg": 1
      }
    },
    "slots": [
      {
        "id": "hero",
        "label": "Hero",
        "selectedVariant": "device",
        "variants": [
          {
            "id": "device",
            "sceneTemplate": "gitci.core.hero-device",
            "props": {
              "headline": "Show the moment that sells the app",
              "subheadline": "Use an existing screenshot, a strong benefit, and a clean device frame.",
              "screenshot": {
                "kind": "asset",
                "path": "../../assets/iphone/hero.svg",
                "alt": "Primary app screen"
              },
              "device": "iphone-2d",
              "devicePose": "tilt-right"
            }
          }
        ]
      },
      {
        "id": "feature",
        "label": "Feature Close-Up",
        "selectedVariant": "detail",
        "variants": [
          {
            "id": "detail",
            "sceneTemplate": "gitci.core.feature-closeup",
            "props": {
              "headline": "Make one workflow obvious",
              "subheadline": "Pair a short claim with the exact screen that proves it.",
              "screenshot": {
                "kind": "asset",
                "path": "../../assets/iphone/detail.svg",
                "alt": "Detailed feature screen"
              },
              "device": "iphone-2d"
            }
          }
        ]
      },
      {
        "id": "overview",
        "label": "Overview",
        "selectedVariant": "overview-hero",
        "variants": [
          {
            "id": "overview-hero",
            "sceneTemplate": "gitci.core.hero-device",
            "props": {
              "headline": "Adapt the story across every target",
              "subheadline": "Use target-aware variants when iPhone, iPad, or Mac needs a different composition.",
              "screenshot": {
                "kind": "asset",
                "path": "../../assets/ipad/overview.svg",
                "alt": "Wide app overview"
              },
              "device": "ipad-2d",
              "devicePose": "front"
            }
          }
        ]
      }
    ]
  }
}
