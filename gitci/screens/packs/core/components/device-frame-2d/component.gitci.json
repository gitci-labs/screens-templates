{
  "$schema": "https://screens.gitci.com/schemas/component.gitci.schema.json",
  "schemaVersion": 1,
  "id": "gitci.core.device-frame-2d",
  "name": "Device Frame 2D",
  "pack": "gitci.core",
  "entry": "@gitci/screens-templates-core",
  "export": "DeviceFrame2D",
  "category": "device-frames",
  "tags": ["device", "frame", "2d"],
  "propsSchema": {
    "type": "object",
